# Copy this file to .env and fill in your values.
# SkillPilot AI runs fully in offline "mock mode" without a Gemini key —
# every agent has a deterministic rule-based fallback. Add a key below to
# switch every agent over to live Gemini reasoning.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Flask
SECRET_KEY=change-me-in-production
PORT=5000
